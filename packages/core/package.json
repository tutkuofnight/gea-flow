{
  "name": "@gea-flow/core",
  "version": "0.0.3",
  "description": "React Flow-style node editor for the Gea framework",
  "license": "MIT",
  "author": "Tutku Ucan",
  "homepage": "https://github.com/tutkuofnight/gea-flow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutkuofnight/gea-flow.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/tutkuofnight/gea-flow/issues"
  },
  "keywords": [
    "gea",
    "geajs",
    "node-editor",
    "flow",
    "graph",
    "react-flow",
    "diagram",
    "xyflow",
    "visual-editor",
    "gea-flow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && cp src/styles.css dist/styles.css",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@geajs/core": "^1.3.0"
  },
  "dependencies": {
    "@xyflow/system": "^0.0.76"
  },
  "devDependencies": {
    "@geajs/core": "^1.3.0",
    "@geajs/vite-plugin": "^1.3.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}
